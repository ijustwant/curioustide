# Database
POSTGRES_USER=ct
POSTGRES_PASSWORD=changeme_strong_password

# Redis (no password in dev — add requirepass in prod)

# MinIO object storage
MINIO_ROOT_USER=ctminio
MINIO_ROOT_PASSWORD=changeme_minio_password

# LiveKit SFU
# Generate with: openssl rand -hex 16 (key) and openssl rand -hex 32 (secret)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret1234567890abcdef

# JWT signing secret (min 32 chars)
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long

# Frontend public URLs (change for production)
VITE_API_URL=http://localhost:4000
VITE_LIVEKIT_URL=ws://localhost:7880

# Max free channels per user (0 = unlimited)
MAX_FREE_CHANNELS=3

# Stripe payments
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get webhook secret from https://dashboard.stripe.com/webhooks after adding endpoint /payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL used in Stripe success/cancel redirect
FRONTEND_URL=http://localhost

# Admin emails (comma-separated) — bypass payment, create unlimited channels
ADMIN_EMAILS=admin@example.com

# SMTP email (optional — skip to disable timer emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
# For Gmail: use an App Password (not your real password)
# https://myaccount.google.com/apppasswords
SMTP_PASS=your_app_password
